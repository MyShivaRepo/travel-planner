@prefix :     <https://github.com/MyShivaRepo/travel-planner/ontology#> .
@prefix ex:   <https://github.com/MyShivaRepo/travel-planner/instances#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

# =============================================================================
# Travel Planner — Exemples d'individus (TBox → ABox)
# Cet ABox exerce les principales contraintes du concept_model.ttl :
#   - cardinalités min/max
#   - énumérations (TypeDestination, ModeDeTransport)
#   - disjonction Restaurant / Point de passage
# =============================================================================

<https://github.com/MyShivaRepo/travel-planner/instances>
    a owl:Ontology ;
    owl:imports <https://github.com/MyShivaRepo/travel-planner/ontology> ;
    rdfs:comment "Voyage exemple : 2 jours au Japon (Tokyo → Kyoto)."@fr .

# ─── DESTINATION ──────────────────────────────────────────────────────────────

ex:dest_japon a :Destination ;
    :nom             "Japon" ;
    :typeDestination "Pays" ;
    :contientPOI     ex:poi_mont_fuji , ex:poi_fushimi_inari ;
    :contientActivité ex:act_cours_cuisine ;
    :aVoyage         ex:voyage_japon .

# ─── POIs ─────────────────────────────────────────────────────────────────────

ex:poi_mont_fuji a :POI ;
    :rang        1 ;
    :nom         "Mont Fuji" ;
    :typePOI     "Nature" ;
    :description "Sommet emblématique du Japon." ;
    :latitude    35.3606 ;
    :longitude   138.7274 .

ex:poi_fushimi_inari a :POI ;
    :rang        2 ;
    :nom         "Fushimi Inari Taisha" ;
    :typePOI     "Histoire" ;
    :description "Sanctuaire shinto célèbre pour ses milliers de torii rouges." ;
    :latitude    34.9671 ;
    :longitude   135.7727 .

# ─── ACTIVITÉ ─────────────────────────────────────────────────────────────────

ex:act_cours_cuisine a :Activité ;
    :rang          1 ;
    :nom           "Cours de cuisine japonaise (sushi & ramen)" ;
    :typeActivité  "Cuisine" ;
    :description   "Cours de 3 h dans une école traditionnelle de Kyoto." ;
    :latitude      35.0116 ;
    :longitude     135.7681 ;
    :fournisseur   "https://www.kyoto-cooking-class.example"^^xsd:anyURI .

# ─── HÔTELS ───────────────────────────────────────────────────────────────────

ex:hotel_park_hyatt_tokyo a :Hôtel ;
    :nom       "Park Hyatt Tokyo" ;
    :adresse   "3-7-1-2 Nishi Shinjuku, Tokyo" ;
    :latitude  35.6855 ;
    :longitude 139.6909 ;
    :budget    "650.00"^^xsd:decimal .

ex:hotel_tawaraya_kyoto a :Hôtel ;
    :nom       "Tawaraya Ryokan" ;
    :adresse   "278 Nakahakusan-cho, Nakagyo, Kyoto" ;
    :latitude  35.0116 ;
    :longitude 135.7700 ;
    :budget    "450.00"^^xsd:decimal .

# ─── RESTAURANTS ──────────────────────────────────────────────────────────────

ex:resto_sushi_saito a :Restaurant ;
    :nom       "Sushi Saito" ;
    :adresse   "1-4-5 Roppongi, Minato-ku, Tokyo" ;
    :latitude  35.6610 ;
    :longitude 139.7375 ;
    :budget    "200.00"^^xsd:decimal .

ex:resto_kikunoi a :Restaurant ;
    :nom       "Kikunoi Honten" ;
    :adresse   "459 Shimokawara-cho, Higashiyama, Kyoto" ;
    :latitude  35.0035 ;
    :longitude 135.7805 ;
    :budget    "180.00"^^xsd:decimal .

# ─── VOYAGE ───────────────────────────────────────────────────────────────────

ex:voyage_japon a :Voyage ;
    :contientJour ex:jour_1 , ex:jour_2 .

# ─── JOUR 1 — Tokyo (Mont Fuji) ───────────────────────────────────────────────

ex:jour_1 a :Jour ;
    :numéro          1 ;
    :visite          ex:poi_mont_fuji ;
    :séjourneÀ       ex:hotel_park_hyatt_tokyo ;
    :dîneÀ           ex:resto_sushi_saito ;
    :comporteSegment ex:seg_1_1 , ex:seg_1_2 .

ex:seg_1_1 a :Segment ;
    :départ          ex:hotel_park_hyatt_tokyo ;
    :arrivée         ex:poi_mont_fuji ;
    :modeDeTransport "voiture de location" ;
    :distance        "120.5"^^xsd:decimal ;
    :durée           "2.0"^^xsd:decimal ;
    :budget          "60.00"^^xsd:decimal .

ex:seg_1_2 a :Segment ;
    :départ          ex:poi_mont_fuji ;
    :arrivée         ex:hotel_park_hyatt_tokyo ;
    :modeDeTransport "voiture de location" ;
    :distance        "120.5"^^xsd:decimal ;
    :durée           "2.0"^^xsd:decimal ;
    :budget          "60.00"^^xsd:decimal .

# ─── JOUR 2 — Kyoto (Fushimi Inari + cours de cuisine) ────────────────────────

ex:jour_2 a :Jour ;
    :numéro          2 ;
    :visite          ex:poi_fushimi_inari ;
    :réalise         ex:act_cours_cuisine ;
    :séjourneÀ       ex:hotel_tawaraya_kyoto ;
    :dîneÀ           ex:resto_kikunoi ;
    :comporteSegment ex:seg_2_1 , ex:seg_2_2 , ex:seg_2_3 .

# Tokyo → Kyoto (Shinkansen)
ex:seg_2_1 a :Segment ;
    :départ          ex:hotel_park_hyatt_tokyo ;
    :arrivée         ex:poi_fushimi_inari ;
    :modeDeTransport "train" ;
    :distance        "513.0"^^xsd:decimal ;
    :durée           "2.5"^^xsd:decimal ;
    :budget          "140.00"^^xsd:decimal .

# Fushimi Inari → cours de cuisine (à pied)
ex:seg_2_2 a :Segment ;
    :départ          ex:poi_fushimi_inari ;
    :arrivée         ex:act_cours_cuisine ;
    :modeDeTransport "métro" ;
    :distance        "5.2"^^xsd:decimal ;
    :durée           "0.4"^^xsd:decimal ;
    :budget          "3.00"^^xsd:decimal .

# Cours de cuisine → hôtel Kyoto (à pied)
ex:seg_2_3 a :Segment ;
    :départ          ex:act_cours_cuisine ;
    :arrivée         ex:hotel_tawaraya_kyoto ;
    :modeDeTransport "à pied" ;
    :distance        "0.3"^^xsd:decimal ;
    :durée           "0.05"^^xsd:decimal ;
    :budget          "0.00"^^xsd:decimal .
